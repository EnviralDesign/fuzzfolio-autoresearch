{
  "llm": {
    "explorer_profile": "openai-mini",
    "supervisor_profile": "xai-grok"
  },
  "providers": {
    "openai-mini": {
      "type": "openai",
      "api_base": "https://api.openai.com/v1",
      "api_key_ref": "openai_main",
      "model": "gpt-5.4-mini",
      "temperature": 0.2,
      "max_tokens": 3200,
      "timeout_seconds": 120
    },
    "xai-grok": {
      "type": "xai",
      "api_base": "https://api.x.ai/v1",
      "api_key_ref": "xai_main",
      "model": "grok-4.20-reasoning",
      "temperature": 0.2,
      "max_tokens": 3200,
      "timeout_seconds": 180
    },
    "xai-multi-agent-sample": {
      "type": "xai",
      "api_base": "https://api.x.ai/v1",
      "api_key_ref": "xai_main",
      "model": "grok-4.20-multi-agent",
      "transport": "responses",
      "temperature": 0.2,
      "max_tokens": 3200,
      "timeout_seconds": 180
    },
    "openrouter-sample": {
      "type": "openrouter",
      "api_base": "https://openrouter.ai/api/v1",
      "api_key_ref": "openrouter_main",
      "model": "openai/gpt-4.1-mini",
      "temperature": 0.2,
      "max_tokens": 3200,
      "timeout_seconds": 120
    }
  },
  "fuzzfolio": {
    "cli_command": "fuzzfolio-agent-cli",
    "base_url": "http://localhost:7946/api/dev",
    "auth_profile": "robot"
  },
  "research": {
    "max_steps": 40,
    "recent_attempts_window": 16,
    "label_prefix": "agentic",
    "auto_seed_prompt": true,
    "plot_lower_is_better": false,
    "compact_trigger_tokens": 12000,
    "compact_keep_recent_messages": 4,
    "supervisor_recent_steps": 6,
    "finish_min_attempts": 4,
    "run_wrap_up_steps": 3,
    "phase_early_ratio": 0.35,
    "phase_late_ratio": 0.75,
    "horizon_early_months": 3,
    "horizon_mid_months": 12,
    "horizon_late_months": 24,
    "horizon_wrap_up_months": 36
  },
  "supervisor": {
    "max_steps": 200,
    "window_start": "23:00",
    "window_end": "05:00",
    "timezone": "America/Chicago",
    "stop_mode": "after_step"
  }
}

  "fuzzfolio": {
    "cli_command": "fuzzfolio-agent-cli",
    "base_url": "http://localhost:7946/api/dev",
    "auth_profile": "robot"
  },
  "research": {
    "max_steps": 40,
    "recent_attempts_window": 16,
    "label_prefix": "agentic",
    "auto_seed_prompt": true,
    "quality_score_preset": "profile-drop",
    "plot_lower_is_better": false,
    "compact_trigger_tokens": 12000,
    "compact_target_tokens": 9000,
    "presentation_metadata_provider_profile": "codex-sample",
    "recent_step_window_steps": 6,
    "finish_min_attempts": 4,
    "run_wrap_up_steps": 3,
    "phase_early_ratio": 0.35,
    "phase_late_ratio": 0.75,
    "horizon_early_months": 3,
    "horizon_mid_months": 12,
    "horizon_late_months": 24,
    "horizon_wrap_up_months": 36,
    "coverage_reference_timeframe": "M15",
    "coverage_min_mid_months": 11,
    "coverage_min_wrap_up_months": 34
  },
  "supervise": {
    "max_steps": 200,
    "window_enabled": true,
    "window_start": "23:00",
    "window_end": "05:00",
    "timezone": "America/Chicago",
    "stop_mode": "after_step",
    "soft_wrap_minutes": 30,
    "auto_restart_terminal_sessions": false
  },
  "manager": {
    "enabled": true,
    "profiles": [
      "openai-mini"
    ],
    "max_candidate_families_in_packet": 8
  }
}
